# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly text
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.rego      text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.mcpb      binary
*.tgz       binary
